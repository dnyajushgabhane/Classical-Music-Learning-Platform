# Render Backend URL (your Render service's public URL, no trailing slash)
# e.g. https://classical-music-backend.onrender.com
VITE_API_URL=https://your-render-backend-url.onrender.com

# LiveKit Cloud URL (only needed if you want the client to directly connect)
# e.g. wss://your-project.livekit.cloud
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud


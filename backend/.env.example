NODE_ENV=production
PORT=5001

# MongoDB Atlas connection string (use Atlas for Render, NOT localhost)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/raagvidya?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-me-to-a-strong-random-secret

# Your Vercel frontend URL (no trailing slash)
CLIENT_ORIGIN=https://your-vercel-app.vercel.app

# LiveKit SFU (https://cloud.livekit.io or self-hosted)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Razorpay (optional, for payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

